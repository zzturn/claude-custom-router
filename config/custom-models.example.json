{
  "port": 8082,
  "debug": false,
  "Router": {
    "default": "my-default-model",
    "longContext": "model-with-large-context",
    "longContextThreshold": 60000,
    "image": "vision-model",
    "background": "fast-cheap-model",
    "think": "reasoning-model",
    "webSearch": "search-capable-model"
  },
  "models": {
    "my-default-model": {
      "name": "actual-model-name",
      "baseURL": "https://api.provider.com/v1",
      "apiKey": "${YOUR_API_KEY_ENV_VAR}",
      "maxTokens": 8192
    },
    "model-with-large-context": {
      "name": "long-context-model",
      "baseURL": "https://api.provider.com/v1",
      "apiKey": "${YOUR_API_KEY_ENV_VAR}",
      "maxTokens": 16384
    },
    "vision-model": {
      "name": "vision-model-name",
      "baseURL": "https://api.provider.com/v1",
      "apiKey": "${YOUR_API_KEY_ENV_VAR}"
    },
    "fast-cheap-model": {
      "name": "fast-model",
      "baseURL": "https://api.provider.com/v1",
      "apiKey": "${YOUR_API_KEY_ENV_VAR}"
    },
    "reasoning-model": {
      "name": "reasoning-model-name",
      "baseURL": "https://api.provider.com/v1",
      "apiKey": "${YOUR_API_KEY_ENV_VAR}"
    },
    "search-capable-model": {
      "name": "search-model-name",
      "baseURL": "https://api.provider.com/v1",
      "apiKey": "${YOUR_API_KEY_ENV_VAR}"
    }
  }
}
